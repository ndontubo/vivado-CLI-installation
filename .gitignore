# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
*.egg
build/
dist/

# --- macOS ---
.DS_Store

# --- vivado-mac state & VM artifacts ---
# State tracking lives at ~/.vivado-mac/state.json (outside the repo), but
# ignore a local copy too in case of accidental in-repo testing.
.vivado-mac/
*.qcow2
*.iso
*.img

# --- cloud-init generated artifacts (regenerated by `init`, not source) ---
cloud-init/generated/
*.seed.iso

# --- Vivado installer & license files ---
# HARD CONSTRAINT: this repo must never contain Vivado installer binaries
# or license files (AMD's EULA prohibits redistribution — see
# ARCHITECTURE.md / README.md "What this tool will NOT do"). These patterns
# are a safety net, not the actual policy enforcement — never `git add -f`
# past this file to include an installer or license.
Vivado*.tar.gz
Vivado*.bin
*.lic
*.dat
xilinx*.lic
Xilinx_*_Installer*

# --- Secrets / credentials ---
# SSH keys generated for guest VM access, tokens, env files.
*.pem
id_rsa*
id_ed25519*
.env
*.token

# --- Editor / OS cruft ---
.vscode/
.idea/
*.swp
# --- Phase 1 additions: vfkit uses raw disk images, not qcow2 ---
# (Apple Virtualization Framework has no qcow2 support -- see
# ARCHITECTURE.md's "Disk footprint & storage strategy" section)
*.raw
*.fd
